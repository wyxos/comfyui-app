{
  "name": "comfyui-companion-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "vue-tsc -b && vite build",
    "extension:typecheck": "tsc -p extension/tsconfig.json",
    "extension:build": "npm run extension:typecheck && vite build --config extension/vite.config.ts",
    "extension:dev": "vite build --config extension/vite.config.ts --watch",
    "extension:package": "npm run extension:build && node scripts/package-extension.mjs",
    "extension:package:local": "npm run extension:package -- --bump=codex",
    "atlas:favorite-downloaded": "node scripts/atlas-favorite-downloaded-assets.mjs",
    "atlas:favorite-downloaded:dry-run": "node scripts/atlas-favorite-downloaded-assets.mjs --dry-run",
    "civitai:archive:backfill": "node scripts/backfill-civitai-archives.mjs",
    "civitai:archive:backfill:dry-run": "node scripts/backfill-civitai-archives.mjs --dry-run",
    "civitai:archive:backfill:missing-media": "node scripts/backfill-civitai-archives.mjs --missing-media-only",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview --host 127.0.0.1 --port 3210",
    "start": "node server/index.mjs",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.9",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
